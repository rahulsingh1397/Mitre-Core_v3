# ===========================================================================
# MITRE-CORE Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ===========================================================================

# ---------------------------------------------------------------------------
# Flask / Application
# ---------------------------------------------------------------------------
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=change-me-to-a-random-64-char-string
PORT=5000

# ---------------------------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-a-different-random-64-char-string
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# Default admin credentials (change immediately after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-immediately

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed origins. Use * only for development.
CORS_ALLOWED_ORIGINS=http://localhost:5000

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATELIMIT_DEFAULT=200 per hour
RATELIMIT_STORAGE_URI=memory://

# ---------------------------------------------------------------------------
# Database (SQLite for persistence)
# ---------------------------------------------------------------------------
DATABASE_URI=sqlite:///mitre_core.db

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---------------------------------------------------------------------------
# SIEM Config Encryption
# ---------------------------------------------------------------------------
# Fernet key for encrypting stored SIEM credentials. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SIEM_ENCRYPTION_KEY=
